<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}} | Leaderboard SSR</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Serif+4:opsz,wght@8..60,500;8..60,700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="background-shape bg-a"></div>
    <div class="background-shape bg-b"></div>
    <header class="site-header">
      <div class="header-brand">
        <p class="eyebrow">Gaming Analytics Platform</p>
        <h1><a href="/">PulseBoard</a></h1>
      </div>
      <nav class="top-nav">
        <div class="nav-section">
          <p class="nav-label">Core</p>
          {{#each primaryNav}}
            {{#if external}}
              <a href="/{{slug}}" target="_blank" rel="noreferrer">{{label}}</a>
            {{else if (eq slug "leaderboard")}}
              <a href="/leaderboard">{{label}}</a>
            {{else if (eq slug "users")}}
              <a href="/users">{{label}}</a>
            {{else}}
              <a href="/{{slug}}">{{label}}</a>
            {{/if}}
          {{/each}}
        </div>
        <div class="nav-divider"></div>
        <div class="nav-section">
          <p class="nav-label">Company</p>
          {{#each companyNav}}
            <a href="/{{slug}}">{{label}}</a>
          {{/each}}
        </div>
        <div class="nav-divider"></div>
        <div class="nav-section">
          <p class="nav-label">Developers</p>
          {{#each developerNav}}
            <a href="{{slug}}" target="_blank" rel="noreferrer">{{label}}</a>
          {{/each}}
        </div>
      </nav>
    </header>
    <main class="content">
      {{{body}}}
    </main>
    <footer class="site-footer">
      <div class="footer-content">
        <div class="footer-section">
          <h4>Navigate</h4>
          <ul>
            {{#each primaryNav}}
              <li>
                {{#if external}}
                  <a href="/{{slug}}" target="_blank" rel="noreferrer">{{label}}</a>
                {{else if (eq slug "leaderboard")}}
                  <a href="/leaderboard">{{label}}</a>
                {{else if (eq slug "users")}}
                  <a href="/users">{{label}}</a>
                {{else}}
                  <a href="/{{slug}}">{{label}}</a>
                {{/if}}
              </li>
            {{/each}}
          </ul>
        </div>
        <div class="footer-section">
          <h4>Company</h4>
          <ul>
            {{#each companyNav}}
              <li><a href="/{{slug}}">{{label}}</a></li>
            {{/each}}
          </ul>
        </div>
        <div class="footer-section">
          <h4>API &amp; Docs</h4>
          <ul>
            {{#each developerNav}}
              <li><a href="{{slug}}" target="_blank" rel="noreferrer">{{label}}</a></li>
            {{/each}}
            <li><a href="/leaderboard">Full Leaderboard Page</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>About PulseBoard</h4>
          <p>A competitive ranking platform built for scale, reliability, and clarity.</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 PulseBoard. Gaming Analytics Platform.</p>
      </div>
    </footer>
  </body>
</html>
