<section class="hero-block">
  <p class="eyebrow">Live Competitive Ranking</p>
  <h2>{{title}}</h2>
  <p>
    PulseBoard tracks per-game performance across four titles and surfaces score data
    for players and business operators managing competitive products at scale.
  </p>
</section>

<nav class="game-tabs">
  <a href="/leaderboard" class="game-tab{{#unless currentGame}} active{{/unless}}">Overall</a>
  {{#each games}}
    <a href="/leaderboard?game={{id}}" class="game-tab{{#if (eq id ../currentGame.id)}} active{{/if}}">{{name}}</a>
  {{/each}}
</nav>

<section class="stats-grid">
  <article class="stats-card">
    <p>Total Players</p>
    <h3>{{snapshot.totalUsers}}</h3>
  </article>
  <article class="stats-card">
    <p>Games</p>
    <h3>{{snapshot.totalGames}}</h3>
  </article>
  <article class="stats-card">
    <p>Top Score</p>
    <h3>{{snapshot.topScore}}</h3>
  </article>
</section>

<section class="panel">
  <h3>{{#if currentGame}}{{currentGame.name}} — {{currentGame.genre}}{{else}}Overall Rankings{{/if}}</h3>
  {{#if currentGame}}<p class="eyebrow">{{currentGame.description}}</p>{{/if}}
  <table>
    <thead>
      <tr>
        <th>Rank</th>
        <th>Player</th>
        <th>Score</th>
      </tr>
    </thead>
    <tbody>
      {{#each leaderboard}}
        <tr>
          <td>
            {{#if @first}}
              <span class="rank-badge gold">#{{rank}}</span>
            {{else}}
              <span class="rank-badge">#{{rank}}</span>
            {{/if}}
          </td>
          <td><a href="/users/{{userId}}">{{name}}</a></td>
          <td>{{score}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>
</section>

<section class="panel">
  <h3>Platform Announcements</h3>
  <ul class="announcement-list">
    {{#each snapshot.announcements}}
      <li>
        <strong>{{title}}</strong>
        <p>{{summary}}</p>
      </li>
    {{/each}}
  </ul>
</section>
